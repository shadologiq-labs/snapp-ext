{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "webextensions": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-console": "off",
    "no-var": "error",
    "prefer-const": "warn",
    "eqeqeq": ["error", "smart"],
    "quotes": ["error", "double", { "avoidEscape": true, "allowTemplateLiterals": true }],
    "semi": ["error", "always"]
  },
  "globals": {
    "chrome": "readonly",
    "browser": "readonly",
    "CSS": "readonly",
    "SNAPP_LIB": "writable",
    "LINKER_LIB": "writable",
    "g_form": "readonly"
  },
  "overrides": [
    {
      "files": ["scripts/**/*.js"],
      "env": { "node": true, "browser": false }
    },
    {
      "files": ["tests/**/*.js"],
      "env": { "node": true, "browser": true },
      "parserOptions": { "sourceType": "module" },
      "globals": {
        "describe": "readonly",
        "it": "readonly",
        "expect": "readonly",
        "beforeEach": "readonly",
        "afterEach": "readonly"
      }
    }
  ]
}
