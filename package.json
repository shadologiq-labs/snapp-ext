{
  "name": "snapp-ext",
  "version": "0.9.2",
  "description": "ServiceNow helper extension",
  "scripts": {
    "build": "node scripts/build.js",
    "build:chrome": "node scripts/build.js",
    "build:firefox": "node scripts/build.js",
    "validate": "node scripts/validate.js",
    "lint": "eslint src/ scripts/ tests/",
    "lint:fix": "eslint src/ scripts/ tests/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run validate && npm run test"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "happy-dom": "^14.12.3",
    "vitest": "^1.6.1"
  }
}
